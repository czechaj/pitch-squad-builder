generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model User {
  id             String           @id @default(cuid())
  phoneE164      String           @unique
  role           String           @default("USER")
  createdAt      DateTime         @default(now())
  roomsAdmined   Room[]           @relation("RoomAdmin")
  memberships    RoomMembership[]
  playerProfiles PlayerProfile[]
  players        Player[]
}

model OtpCode {
  id        String   @id @default(cuid())
  phoneE164 String
  code      String
  expiresAt DateTime
  createdAt DateTime @default(now())
}

model Room {
  id             String           @id @default(cuid())
  name           String
  adminUserId    String
  admin          User             @relation("RoomAdmin", fields: [adminUserId], references: [id])
  createdAt      DateTime         @default(now())
  invites        Invite[]
  memberships    RoomMembership[]
  playerProfiles PlayerProfile[]
  players        Player[]
}

model Invite {
  id        String    @id @default(cuid())
  roomId    String
  room      Room      @relation(fields: [roomId], references: [id])
  phoneE164 String
  refCode   String    @unique
  expiresAt DateTime
  usedAt    DateTime?
  createdAt DateTime  @default(now())
}

model RoomMembership {
  id       String   @id @default(cuid())
  roomId   String
  userId   String
  joinedAt DateTime @default(now())
  room     Room     @relation(fields: [roomId], references: [id])
  user     User     @relation(fields: [userId], references: [id])

  @@unique([roomId, userId])
}

model PlayerProfile {
  id                   String   @id @default(cuid())
  roomId               String
  userId               String
  name                 String
  primaryPosition      String
  secondaryPosition    String?
  alternativePositions String
  statsJson            String
  createdAt            DateTime @default(now())
  updatedAt            DateTime @updatedAt
  room                 Room     @relation(fields: [roomId], references: [id])
  user                 User     @relation(fields: [userId], references: [id])
  Player               Player[]

  @@unique([roomId, userId])
}

model Player {
  id                   String         @id @default(cuid())
  roomId               String?
  userId               String?
  profileId            String?
  room                 Room?          @relation(fields: [roomId], references: [id])
  user                 User?          @relation(fields: [userId], references: [id])
  profile              PlayerProfile? @relation(fields: [profileId], references: [id])
  name                 String
  power                Int
  primaryPosition      String
  secondaryPosition    String?
  alternativePositions String
  statsJson            String
  createdAt            DateTime       @default(now())
}
