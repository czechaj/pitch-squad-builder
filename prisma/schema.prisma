generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model User {
  id        String   @id @default(cuid())
  phoneE164 String   @unique
  role      String   @default("USER")
  createdAt DateTime @default(now())
  rooms     Room[]   @relation("RoomAdmin")
  players   Player[]
}

model OtpCode {
  id        String   @id @default(cuid())
  phoneE164 String
  code      String
  expiresAt DateTime
  createdAt DateTime @default(now())
}

model Room {
  id          String   @id @default(cuid())
  name        String
  adminUserId String
  admin       User     @relation("RoomAdmin", fields: [adminUserId], references: [id])
  createdAt   DateTime @default(now())
  invites     Invite[]
}

model Invite {
  id        String    @id @default(cuid())
  roomId    String
  room      Room      @relation(fields: [roomId], references: [id])
  phoneE164 String
  refCode   String    @unique
  expiresAt DateTime
  usedAt    DateTime?
  createdAt DateTime  @default(now())
}

model Player {
  id               String   @id @default(cuid())
  userId           String?
  user             User?    @relation(fields: [userId], references: [id])
  name             String
  power            Int
  primaryPosition  String
  secondaryPosition String?
  alternativePositions String
  statsJson        String
  createdAt        DateTime @default(now())
}
