generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DATABASE_URL_UNPOOLED")
}

enum Role {
  ADMIN
  USER
}

enum MembershipStatus {
  ACTIVE
  PENDING
}

model User {
  id            String       @id @default(cuid())
  phoneE164     String       @unique
  role          Role         @default(USER)
  createdAt     DateTime     @default(now())
  adminRooms    Room[]       @relation("roomAdmin")
  memberships   RoomMember[]
  ratingsGiven  MatchRating[] @relation("ratingsGiven")
}

model Room {
  id          String        @id @default(cuid())
  name        String
  adminUserId String
  adminUser   User          @relation("roomAdmin", fields: [adminUserId], references: [id])
  createdAt   DateTime      @default(now())
  members     RoomMember[]
  invites     Invite[]
  players     Player[]
  matches     Match[]
}

model RoomMember {
  id        String           @id @default(cuid())
  roomId    String
  userId    String
  status    MembershipStatus @default(ACTIVE)
  createdAt DateTime         @default(now())
  room      Room             @relation(fields: [roomId], references: [id])
  user      User             @relation(fields: [userId], references: [id])

  @@unique([roomId, userId])
}

model Invite {
  id          String   @id @default(cuid())
  roomId       String
  phoneE164    String
  refCode      String   @unique
  expiresAt    DateTime
  usedAt       DateTime?
  createdAt    DateTime @default(now())
  room         Room     @relation(fields: [roomId], references: [id])
}

model Player {
  id          String       @id @default(cuid())
  roomId       String
  userId       String?
  displayName  String
  attributes   Json
  createdAt    DateTime     @default(now())
  room         Room          @relation(fields: [roomId], references: [id])
  ratings      MatchRating[] @relation("ratingsTarget")
}

model Match {
  id        String       @id @default(cuid())
  roomId     String
  playedAt   DateTime
  createdAt  DateTime     @default(now())
  room       Room         @relation(fields: [roomId], references: [id])
  ratings    MatchRating[]
}

model MatchRating {
  id             String   @id @default(cuid())
  matchId         String
  raterUserId     String
  targetPlayerId  String
  score           Int
  createdAt       DateTime @default(now())
  match           Match    @relation(fields: [matchId], references: [id])
  rater           User     @relation("ratingsGiven", fields: [raterUserId], references: [id])
  targetPlayer    Player   @relation("ratingsTarget", fields: [targetPlayerId], references: [id])

  @@unique([matchId, raterUserId, targetPlayerId])
}
